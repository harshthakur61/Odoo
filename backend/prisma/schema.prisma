generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String
  role     String

  driver   Driver?
  tripEvents TripEvent[]
  verifiedDriverDocuments DriverDocument[] @relation("VerifiedBy")
}

model Vehicle {
  id              Int               @id @default(autoincrement())
  regNumber       String            @unique
  name            String
  type            String
  maxLoad         Float
  odometer        Float             @default(0)
  acquisitionCost Float             @default(0)
  status          String            @default("AVAILABLE")
  region          String?
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
}

model Driver {
  id              Int      @id @default(autoincrement())
  name            String
  licenseNumber   String   @unique
  licenseCategory String
  licenseExpiry   DateTime
  contact         String?
  safetyScore     Int      @default(100)
  status          String   @default("AVAILABLE")
  trips           Trip[]

  userId          Int?     @unique
  user            User?    @relation(fields: [userId], references: [id])
  documents       DriverDocument[]
  emergencyReports EmergencyReport[]
}

model Trip {
  id              Int        @id @default(autoincrement())
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  status          String     @default("DRAFT")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  
  vehicleId       Int
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])
  driverId        Int
  driver          Driver     @relation(fields: [driverId], references: [id])
  
  fuelLogs        FuelLog[]
  expenses        Expense[]
  events          TripEvent[]
  emergencyReports EmergencyReport[]
}

model MaintenanceLog {
  id          Int       @id @default(autoincrement())
  type        String
  description String?
  cost        Float
  status      String    @default("ACTIVE")
  startDate   DateTime  @default(now())
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  closedAt    DateTime?
  
  vehicleId   Int
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  liters    Float
  cost      Float
  date      DateTime @default(now())
  
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  tripId    Int?
  trip      Trip?    @relation(fields: [tripId], references: [id])
}

model Expense {
  id          Int      @id @default(autoincrement())
  type        String
  amount      Float
  description String?
  date        DateTime @default(now())
  
  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  tripId      Int?
  trip        Trip?    @relation(fields: [tripId], references: [id])
}

enum DriverDocumentType {
  LICENSE
  INSURANCE
  OTHER
}

enum DriverDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model DriverDocument {
  id              Int                  @id @default(autoincrement())
  driverId        Int
  driver          Driver               @relation(fields: [driverId], references: [id])
  type            DriverDocumentType
  fileUrl         String
  status          DriverDocumentStatus @default(PENDING)
  rejectionReason String?
  uploadedAt      DateTime             @default(now())
  verifiedAt      DateTime?
  expiresAt       DateTime?

  verifiedByUserId Int?
  verifiedByUser   User?               @relation("VerifiedBy", fields: [verifiedByUserId], references: [id])
}

enum TripEventType {
  CREATED
  DISPATCHED
  DRIVER_UPDATE
  COMPLETED
  CANCELLED
  NOTE
}

model TripEvent {
  id              Int          @id @default(autoincrement())
  tripId          Int
  trip            Trip         @relation(fields: [tripId], references: [id])
  type            TripEventType
  message         String
  createdAt       DateTime     @default(now())
  createdByUserId Int?
  createdByUser   User?        @relation(fields: [createdByUserId], references: [id])
}

model EmergencyReport {
  id        Int       @id @default(autoincrement())
  tripId    Int
  trip      Trip      @relation(fields: [tripId], references: [id])
  driverId  Int
  driver    Driver    @relation(fields: [driverId], references: [id])
  message   String
  status    String    @default("PENDING") // PENDING, REVIEWED, RESOLVED
  createdAt DateTime  @default(now())
}
